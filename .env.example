# ============================================================
# .env.example — Variables de entorno del monorepo SGA
# Copia este archivo como .env y rellena los valores reales
# ============================================================

# ── Backend Flask ────────────────────────────────────────────
SECRET_KEY=cambiar-esto-por-una-clave-segura-en-produccion
AUDIT_LOG_ENABLED=True

# ── Base de Datos Oracle ─────────────────────────────────────
ORACLE_USER=tu_usuario
ORACLE_PASSWORD=tu_contraseña
ORACLE_DSN=host:puerto/nombre_servicio
ORACLE_MIN=1
ORACLE_MAX=5

# Ruta al Oracle Instant Client DENTRO del contenedor Docker
# (no modificar si usas el Dockerfile estándar del backend)
ORACLE_CLIENT_PATH=/opt/oracle/instantclient_19_19

# Control de inactividad de sesiones en PDA (en minutos)
SESSION_TIMEOUT_MINUTES=30

